@namespace MudBlazor.Docs.Examples

@inject IScrollManager ScrollManager

<MudStack Row="true">
    <MudButton OnClick="@(() => ScrollManager.LockScrollAsync())" Variant="Variant.Filled">Lock scroll</MudButton>
    <MudButton OnClick="@(() => ScrollManager.UnlockScrollAsync())" Variant="Variant.Filled">Unlock scroll</MudButton>
    <MudButton OnClick="@(() => ScrollManager.ScrollIntoViewAsync("#iresizeobserver", ScrollBehavior.Smooth))" Variant="Variant.Filled">Scroll to resize observer</MudButton>
</MudStack>
