#nullable enable
@namespace MudBlazor.Docs.Examples

<MudDataGrid T="TaskItem" 
             Items="@_tasks"
             TreeData="true"
             ChildrenSelector="@(task => task.SubTasks)"
             HasChildren="@(task => task.SubTasks != null && task.SubTasks.Any())"
             ItemKey="@(task => task.Id.ToString())"
             TreeIndentSize="24"
             @bind-ExpandedItemKeys="@_expandedTasks"
             @ref="_dataGrid">
    <Columns>
        <PropertyColumn Property="t => t.Title" Title="Task Title" />
        <TemplateColumn Title="Status">
            <CellTemplate>
                <MudChip Size="Size.Small" 
                         Color="@GetStatusColor(context.Item.Status)" 
                         Variant="Variant.Filled">
                    @context.Item.Status
                </MudChip>
            </CellTemplate>
        </TemplateColumn>
        <PropertyColumn Property="t => t.DueDate" Title="Due Date" Format="yyyy-MM-dd" />
        <PropertyColumn Property="t => t.LastUpdated" Title="Last Updated" Format="yyyy-MM-dd HH:mm" />
    </Columns>
</MudDataGrid>

<div class="d-flex gap-2 mt-4">
    <MudButton Variant="Variant.Filled" 
               Color="Color.Primary" 
               OnClick="@(() => _dataGrid.ExpandAllAsync())"
               StartIcon="Icons.Material.Filled.UnfoldMore">
        Expand All
    </MudButton>
    <MudButton Variant="Variant.Outlined" 
               Color="Color.Primary" 
               OnClick="@(() => _dataGrid.CollapseAllAsync())"
               StartIcon="Icons.Material.Filled.UnfoldLess">
        Collapse All
    </MudButton>
</div>

