    private Color GetStatusColor(TaskStatus status) => status switch
    {
        TaskStatus.NotStarted => Color.Default,
        TaskStatus.InProgress => Color.Warning,
        TaskStatus.Completed => Color.Success,
        _ => Color.Default
    };

    public class TaskItem
    {
        public int Id { get; set; }
        public string Title { get; set; } = "";
        public TaskStatus Status { get; set; }
        public DateTime DueDate { get; set; }
        public DateTime LastUpdated { get; set; }
        public List<TaskItem> SubTasks { get; set; }
    }

    public enum TaskStatus
    {
        NotStarted,
        InProgress,
        Completed
    }
