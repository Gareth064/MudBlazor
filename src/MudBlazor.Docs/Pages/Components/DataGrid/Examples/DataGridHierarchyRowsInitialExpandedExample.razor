@namespace MudBlazor.Docs.Examples

<MudDataGrid T="OrganizationNode" 
             Items="@_organizationChart" 
             HierarchicalRows="true"
             ChildItemsSelector="@(node => node.Reports)"
             HierarchyIndentSize="32"
             HierarchyInitiallyExpanded="@(node => node.Department == "Engineering")"
             Dense="true"
             Hover="true"
             Bordered="true">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Organization Chart - Engineering Initially Expanded</MudText>
    </ToolBarContent>
    <Columns>
        <PropertyColumn Property="x => x.Name" Title="Name" />
        <PropertyColumn Property="x => x.Position" Title="Position" />
        <PropertyColumn Property="x => x.Department" Title="Department" />
        <PropertyColumn Property="x => x.Email" Title="Email" />
    </Columns>
</MudDataGrid>

@code {
    private class OrganizationNode
    {
        public string Name { get; set; }
        public string Position { get; set; }
        public string Department { get; set; }
        public string Email { get; set; }
        public List<OrganizationNode> Reports { get; set; } = new();
    }

