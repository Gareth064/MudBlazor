@namespace MudBlazor.Docs.Examples

<MudDataGrid T="Employee" Items="@Employees" SelfReferencingHierarchy="true" 
             ChildrenSelector="@(item => item.DirectReports)" 
             HierarchyIndentationSize="@HierarchyIndentationSize"
             Striped="true" Hover="true">
    <Columns>
        <HierarchyColumn />
        <PropertyColumn Property="x => x.Name" Title="Name" />
        <PropertyColumn Property="x => x.Position" Title="Position" />
        <PropertyColumn Property="x => x.Department" Title="Department" />
        <PropertyColumn Property="x => x.Email" Title="Email" />
    </Columns>
</MudDataGrid>

<MudSlider @bind-Value="HierarchyIndentationSize" Min="0" Max="60" Color="Color.Primary" Class="mt-4">
    Hierarchy Indentation: @HierarchyIndentationSize px
</MudSlider>

@code {
    public int HierarchyIndentationSize { get; set; } = 24;

    public class Employee
    {
        public string Name { get; set; } = "";
        public string Position { get; set; } = "";
        public string Department { get; set; } = "";
